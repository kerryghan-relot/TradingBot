# Virtualenvs & Python caches
.venv/
**/__pycache__/
**/*.pyc

# Node / frontend build artefacts (rebuilt inside the image)
**/node_modules/
src/web/frontend/dist/

# Legacy SQLite store & backups
src/bars.db
src/bars.db-*
src/backups/

# Runtime data we never want baked into the image
src/logs/
src/results/
**/*.log

# VCS & local tooling
.git/
.gitignore
.claude/
.env
.env.*

# Docs / planning
*.md
!src/README.md
