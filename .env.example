# ── Copy to .env and fill in — never commit .env ──────────────────────
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────
# Used by the db service AND to build DATABASE_URL for the app services.
POSTGRES_USER=tradingbot
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tradingbot

# Override only if you run Postgres somewhere other than the compose
# `db` service (the default is derived from POSTGRES_* above).
# DATABASE_URL=postgresql://tradingbot:change-me@db:5432/tradingbot

# ── Alpaca (paper trading) ────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Misc ──────────────────────────────────────────────────────────────
TZ=UTC

# ── Dashboard basic-auth (used by setup_vps.sh to build .htpasswd) ─────
# Not read by the app; documents the credentials nginx will enforce.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me
